<VolAutoBus>:
    orientation: 'vertical'

    MDToolbar:
        title: 'VolAuto'
        pos_hint: {'top':1}

    ScreenManager:
        id: kivy_screen_manager
        StartScreen:
            name:'first'
        SecondScreen:
            id: SecondScreen
            name: 'SecondScreen'






<StartScreen@Screen>:
    BoxLayout:
        orientation:'vertical'
        Label:
            text:'[b]yyyyyyyyyyyyy[/b]'

        Button:
            text:'first'
        Button:
            text:'second'
            on_release:app.root.changeScreen(self.text)

<SecondScreen@Screen>:
    BoxLayout:
        Label:
            text: app.getText()
            halign:'center'
            markup: True
            font_size: root.height /20
            text_size:self.width, None
            center_y: .5
            on_ref_press:app.on_ref_press(*args)


